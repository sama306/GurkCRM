---
import "../styles/global.css"
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="GurkCRM — Accede a tu cuenta" />
    <title>GurkCRM — <slot name="title" /></title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="relative flex min-h-dvh items-center justify-center overflow-hidden bg-muted/15 p-4">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute left-1/2 top-0 h-[40rem] w-[40rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-gradient-to-b from-primary/10 to-transparent blur-3xl" />
    </div>
    <div class="flex w-full max-w-sm flex-col items-center gap-6">
      <a href="/" class="flex items-center gap-2.5 font-semibold text-lg tracking-tight text-foreground">
        <span class="flex size-10 items-center justify-center rounded-xl bg-primary text-primary-foreground text-base font-bold">G</span>
        GurkCRM
      </a>
      <slot />
    </div>
  </body>
</html>
