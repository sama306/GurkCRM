---
// Layout para páginas protegidas (/app/*). Sidebar lateral + top bar minimal.
import "../styles/global.css"
import { AppProvider } from "@/components/providers/AppProvider"
import { AuthGuard } from "@/components/auth/AuthGuard"
import { AppSidebar } from "@/components/layout/AppSidebar"
import { UserMenu } from "@/components/layout/UserMenu"
import { Toaster } from "@/components/ui/sonner"
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <slot name="head" />
  </head>
  <body>
    <AppProvider client:load />

    <!-- Sidebar (mobile + desktop) -->
    <AppSidebar client:load />

    <!-- Top bar: solo usuario a la derecha; margin reactivo al sidebar -->
    <header class="fixed right-0 top-0 z-20 flex h-14 items-center justify-end border-b border-border/50 bg-background/80 px-4 backdrop-blur-sm transition-[left] duration-200 ease-out md:px-6" style="left: var(--sidebar-width, 15rem)">
      <UserMenu client:load />
    </header>

    <!-- Main content; margin reactivo al sidebar -->
    <AuthGuard client:load>
      <main class="min-h-dvh pt-14 transition-[margin-left] duration-200 ease-out" style="margin-left: var(--sidebar-width, 15rem)">
        <div class="p-6">
          <slot />
        </div>
      </main>
    </AuthGuard>

    <Toaster client:visible />
  </body>
</html>
