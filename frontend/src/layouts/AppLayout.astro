---
// Layout para páginas protegidas (/app/*). Provee QueryClientProvider + auth init.
import "../styles/global.css"
import { AppProvider } from "@/components/providers/AppProvider"
import { AuthGuard } from "@/components/auth/AuthGuard"
import { UserMenu } from "@/components/layout/UserMenu"
import { AppNavLinks } from "@/components/layout/AppNavLinks"
import { Toaster } from "@/components/ui/sonner"
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <slot name="head" />
  </head>
  <body>
    <!--
      AppProvider solo inicia la verificación de sesión (refresh token).
      NO provee QueryClientProvider porque cada isla client:load de Astro
      es un root React independiente — el provider no llegaría al <slot />.

      Cada página isla que use TanStack Query debe incluir QueryProvider
      como raíz: <QueryProvider><Pagina /></QueryProvider>

      Ver src/components/providers/QueryProvider.tsx para la documentación
      completa de esta decisión arquitectónica.
    -->
    <AppProvider client:load />

    <header class="flex h-14 items-center justify-between border-b px-6">
      <div class="flex items-center gap-6">
        <a href="/app/dashboard" class="text-lg font-bold tracking-tight">
          GurkCRM
        </a>
        <nav class="hidden items-center gap-4 md:flex">
          <a
            href="/app/dashboard"
            class="text-sm text-muted-foreground hover:text-foreground transition-colors"
          >
            Dashboard
          </a>
          <AppNavLinks client:load />
        </nav>
      </div>
      <UserMenu client:load />
    </header>

    <AuthGuard client:load>
      <main class="p-6">
        <slot />
      </main>
    </AuthGuard>

    <Toaster client:visible />
  </body>
</html>
