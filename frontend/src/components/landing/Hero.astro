---
// TODO: Dark mode — el fondo y las clases ya funcionan con variables CSS de shadcn/ui
//       (--background, --foreground, --primary, etc.) cuando se aplica la clase .dark
---

<section class="relative overflow-hidden px-4 pb-20 pt-24 sm:px-6 sm:pb-28 sm:pt-32 lg:px-8">
  <div aria-hidden="true" class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,_var(--color-border)_1px,_transparent_1px),linear-gradient(to_bottom,_var(--color-border)_1px,_transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,#000_70%,transparent_110%)]" />
    <div class="absolute left-1/2 top-0 -z-10 h-[36rem] w-[72rem] -translate-x-1/2 rounded-full bg-gradient-to-b from-primary/15 to-transparent blur-3xl" />
  </div>

  <div class="mx-auto max-w-4xl text-center">
    <h1 class="text-balance text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
      Gestiona tu negocio,
      <span class="text-primary">impulsa tus ventas</span>
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-muted-foreground sm:text-lg sm:leading-8">
      Clientes, oportunidades, tareas y equipo en un solo lugar.
      El CRM que tu empresa necesita para crecer sin complicaciones.
    </p>

    <div class="mt-10 flex items-center justify-center gap-4">
      <a
        href="/register"
        class="inline-flex h-10 items-center justify-center rounded-lg bg-primary px-6 text-sm font-medium text-primary-foreground transition-all hover:bg-primary/80"
      >
        Empezar gratis
      </a>
      <a
        href="#features"
        class="inline-flex h-10 items-center justify-center rounded-lg border border-border bg-background px-6 text-sm font-medium text-foreground transition-all hover:bg-muted"
      >
        Ver funcionalidades
      </a>
    </div>
  </div>
</section>
