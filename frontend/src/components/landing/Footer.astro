---
const year = new Date().getFullYear();
---

<footer class="border-t border-border">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="flex items-center gap-2 text-sm text-muted-foreground">
        <span class="flex size-6 items-center justify-center rounded-md bg-primary text-primary-foreground text-xs font-bold">G</span>
        <span>&copy; {year} GurkCRM. Proyecto de portfolio.</span>
      </div>
      <div class="flex gap-6 text-sm text-muted-foreground">
        <a href="#features" class="transition-colors hover:text-foreground">Funcionalidades</a>
        <a href="#pricing" class="transition-colors hover:text-foreground">Precios</a>
        <a href="#faq" class="transition-colors hover:text-foreground">FAQ</a>
        <a href="#contact" class="transition-colors hover:text-foreground">Contacto</a>
      </div>
    </div>
  </div>
</footer>
